page {
  background: #f6f8fc;
  color: #202124;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
}

.page {
  box-sizing: border-box;
  min-height: 100vh;
  padding: 24rpx 24rpx 56rpx;
}

.topbar,
.hero-meta,
.hero-actions,
.slider-head,
.picker,
.factor-row,
.history-head,
.history-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.topbar {
  margin-bottom: 18rpx;
  padding: 4rpx 2rpx 0;
}

.caption {
  color: #5f6368;
  font-size: 22rpx;
  font-weight: 500;
}

.title {
  margin-top: 4rpx;
  color: #202124;
  font-size: 40rpx;
  font-weight: 700;
  letter-spacing: 0;
}

button {
  box-sizing: border-box;
  min-width: 0;
  padding: 0;
}

.icon-button,
.text-button {
  width: 108rpx;
  height: 60rpx;
  margin: 0;
  border: 1rpx solid #dfe3eb;
  border-radius: 8rpx;
  background: #ffffff;
  color: #1a73e8;
  font-size: 24rpx;
  line-height: 58rpx;
}

.hero-card,
.metric-card,
.section {
  box-sizing: border-box;
  width: 100%;
  overflow: hidden;
  border: 1rpx solid #e5e9f2;
  border-radius: 8rpx;
  background: #ffffff;
  box-shadow: 0 10rpx 28rpx rgba(60, 64, 67, 0.08);
}

.hero-card {
  position: relative;
  padding: 30rpx;
  background: linear-gradient(135deg, #ffffff 0%, #eef5ff 100%);
}

.hero-card::before {
  position: absolute;
  top: 0;
  right: 0;
  left: 0;
  height: 6rpx;
  background: linear-gradient(90deg, #1a73e8, #34a853);
  content: "";
}

.hero-meta {
  gap: 18rpx;
  color: #5f6368;
  font-size: 24rpx;
}

.hero-meta text {
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.hero-meta text:first-child {
  color: #202124;
  font-weight: 700;
}

.price-line {
  display: flex;
  align-items: baseline;
  margin-top: 18rpx;
}

.currency {
  color: #1a73e8;
  font-size: 34rpx;
  font-weight: 700;
}

.price {
  min-width: 0;
  margin-left: 8rpx;
  color: #1a73e8;
  font-size: 72rpx;
  line-height: 1;
  font-weight: 800;
}

.price-note {
  margin-top: 12rpx;
  color: #5f6368;
  font-size: 23rpx;
  line-height: 1.5;
}

.hero-actions {
  gap: 16rpx;
  margin-top: 24rpx;
}

.primary-button,
.secondary-button,
.scenario {
  width: 100%;
  height: 72rpx;
  margin: 0;
  border-radius: 8rpx;
  font-size: 25rpx;
  font-weight: 700;
  line-height: 70rpx;
}

.primary-button {
  flex: 1;
  background: #1a73e8;
  color: #ffffff;
  box-shadow: 0 8rpx 18rpx rgba(26, 115, 232, 0.22);
}

.secondary-button {
  flex: 1;
  border: 1rpx solid #dfe3eb;
  background: rgba(255, 255, 255, 0.88);
  color: #1a73e8;
}

.metric-grid,
.form-grid,
.scenario-grid {
  display: grid;
  min-width: 0;
  gap: 14rpx;
}

.metric-grid {
  grid-template-columns: repeat(3, minmax(0, 1fr));
  margin-top: 16rpx;
}

.metric-card {
  min-width: 0;
  padding: 20rpx 14rpx;
  box-shadow: 0 6rpx 18rpx rgba(60, 64, 67, 0.06);
}

.metric-value,
.metric-label {
  display: block;
}

.metric-value {
  overflow: hidden;
  color: #202124;
  font-size: 27rpx;
  font-weight: 800;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.metric-label {
  margin-top: 8rpx;
  color: #6b7280;
  font-size: 21rpx;
}

.tabbar {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  margin: 22rpx 0 16rpx;
  padding: 6rpx;
  border: 1rpx solid #e5e9f2;
  border-radius: 8rpx;
  background: #eef2f8;
}

.tab {
  min-width: 0;
  height: 64rpx;
  border-radius: 7rpx;
  color: #5f6368;
  text-align: center;
  font-size: 26rpx;
  font-weight: 700;
  line-height: 64rpx;
}

.tab.active {
  background: #ffffff;
  color: #1a73e8;
  box-shadow: 0 4rpx 14rpx rgba(60, 64, 67, 0.1);
}

.section {
  padding: 26rpx;
  margin-top: 16rpx;
}

.section-title {
  color: #111827;
  font-size: 30rpx;
  font-weight: 800;
}

.section-subtitle {
  margin-top: 8rpx;
  margin-bottom: 20rpx;
  color: #6b7280;
  font-size: 22rpx;
  line-height: 1.45;
}

.field {
  min-width: 0;
  margin-top: 14rpx;
}

.label {
  display: block;
  color: #687386;
  font-size: 22rpx;
  font-weight: 600;
}

.input {
  box-sizing: border-box;
  width: 100%;
  min-width: 0;
  height: 76rpx;
  margin-top: 10rpx;
  padding: 0 20rpx;
  border: 1rpx solid #dfe3eb;
  border-radius: 8rpx;
  background: #fbfcff;
  color: #111827;
  font-size: 27rpx;
}

.input:focus {
  border-color: #1a73e8;
  background: #ffffff;
}

.form-grid {
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.slider-card {
  padding: 18rpx 0 10rpx;
  border-bottom: 1rpx solid #edf1f7;
}

.slider-head {
  color: #111827;
  font-size: 26rpx;
  font-weight: 700;
}

.slider-head text:last-child {
  min-width: 54rpx;
  color: #1a73e8;
  text-align: right;
}

.picker {
  box-sizing: border-box;
  width: 100%;
  min-height: 76rpx;
  padding: 0 20rpx;
  margin-top: 14rpx;
  border: 1rpx solid #dfe3eb;
  border-radius: 8rpx;
  background: #fbfcff;
  color: #111827;
  font-size: 26rpx;
}

.picker text {
  min-width: 0;
}

.picker text:first-child {
  flex-shrink: 0;
  color: #687386;
  font-weight: 600;
}

.picker text:last-child {
  overflow: hidden;
  max-width: 64%;
  color: #111827;
  text-align: right;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.scenario-grid {
  grid-template-columns: repeat(3, minmax(0, 1fr));
}

.scenario {
  border: 1rpx solid #d7e3fb;
  background: #edf4ff;
  color: #1a73e8;
  font-size: 24rpx;
}

.factor-row,
.history-item {
  min-width: 0;
  gap: 16rpx;
  padding: 20rpx 0;
  border-top: 1rpx solid #edf1f7;
}

.factor-row:first-of-type,
.history-item:first-of-type {
  border-top: none;
}

.factor-row > view:first-child,
.history-item > view:first-child {
  min-width: 0;
}

.factor-name,
.history-title {
  overflow: hidden;
  color: #111827;
  font-size: 26rpx;
  font-weight: 800;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.factor-value,
.history-meta {
  overflow: hidden;
  margin-top: 6rpx;
  color: #6b7280;
  font-size: 22rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.factor-effect,
.history-price {
  flex-shrink: 0;
  color: #188038;
  font-size: 28rpx;
  font-weight: 800;
}

.reason,
.warning,
.empty {
  padding: 18rpx 0;
  border-top: 1rpx solid #edf1f7;
  color: #374151;
  font-size: 25rpx;
  line-height: 1.55;
}

.reason:first-of-type,
.warning:first-of-type {
  border-top: none;
}

.warning {
  color: #b06000;
}

.empty {
  color: #6b7280;
  text-align: center;
}

@media (max-width: 360px) {
  .page {
    padding-right: 20rpx;
    padding-left: 20rpx;
  }

  .form-grid,
  .metric-grid,
  .scenario-grid {
    grid-template-columns: 1fr;
  }
}
