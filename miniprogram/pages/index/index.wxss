page {
  background: #f8fafd;
  color: #202124;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
}

.page {
  box-sizing: border-box;
  min-height: 100vh;
  padding: 28rpx 28rpx 64rpx;
}

.topbar,
.hero-meta,
.hero-actions,
.slider-head,
.picker,
.factor-row,
.history-head,
.history-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.topbar {
  margin-bottom: 24rpx;
}

.caption {
  color: #5f6368;
  font-size: 23rpx;
  font-weight: 500;
}

.title {
  margin-top: 6rpx;
  color: #202124;
  font-size: 44rpx;
  font-weight: 700;
  letter-spacing: 0;
}

.icon-button,
.text-button {
  margin: 0;
  padding: 0 22rpx;
  height: 64rpx;
  border-radius: 6rpx;
  background: #ffffff;
  color: #1a73e8;
  font-size: 25rpx;
  line-height: 64rpx;
}

.hero-card,
.metric-card,
.section {
  box-sizing: border-box;
  border: 1rpx solid #e8eaed;
  border-radius: 8rpx;
  background: #ffffff;
  box-shadow: 0 2rpx 8rpx rgba(60, 64, 67, 0.1);
}

.hero-card {
  padding: 30rpx;
}

.hero-meta {
  gap: 20rpx;
  color: #5f6368;
  font-size: 24rpx;
}

.price-line {
  display: flex;
  align-items: baseline;
  margin-top: 20rpx;
}

.currency {
  color: #1a73e8;
  font-size: 38rpx;
  font-weight: 700;
}

.price {
  margin-left: 8rpx;
  color: #1a73e8;
  font-size: 82rpx;
  line-height: 1;
  font-weight: 800;
}

.price-note {
  margin-top: 14rpx;
  color: #5f6368;
  font-size: 24rpx;
  line-height: 1.45;
}

.hero-actions {
  gap: 18rpx;
  margin-top: 28rpx;
}

.primary-button,
.secondary-button,
.scenario {
  height: 76rpx;
  margin: 0;
  border-radius: 6rpx;
  font-size: 26rpx;
  font-weight: 600;
  line-height: 76rpx;
}

.primary-button {
  flex: 1;
  background: #1a73e8;
  color: #ffffff;
}

.secondary-button {
  flex: 1;
  border: 1rpx solid #dadce0;
  background: #ffffff;
  color: #1a73e8;
}

.metric-grid,
.form-grid,
.scenario-grid {
  display: grid;
  gap: 16rpx;
}

.metric-grid {
  grid-template-columns: repeat(3, minmax(0, 1fr));
  margin-top: 18rpx;
}

.metric-card {
  min-width: 0;
  padding: 22rpx 16rpx;
}

.metric-value,
.metric-label {
  display: block;
}

.metric-value {
  overflow-wrap: anywhere;
  color: #202124;
  font-size: 28rpx;
  font-weight: 700;
}

.metric-label {
  margin-top: 8rpx;
  color: #5f6368;
  font-size: 22rpx;
}

.tabbar {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  margin: 24rpx 0 18rpx;
  border-bottom: 1rpx solid #e8eaed;
}

.tab {
  position: relative;
  padding: 22rpx 0;
  color: #5f6368;
  text-align: center;
  font-size: 27rpx;
  font-weight: 600;
}

.tab.active {
  color: #1a73e8;
}

.tab.active::after {
  position: absolute;
  right: 28rpx;
  bottom: -1rpx;
  left: 28rpx;
  height: 4rpx;
  border-radius: 4rpx 4rpx 0 0;
  background: #1a73e8;
  content: "";
}

.section {
  padding: 26rpx;
  margin-top: 18rpx;
}

.section-title {
  margin-bottom: 20rpx;
  color: #202124;
  font-size: 30rpx;
  font-weight: 700;
}

.field {
  min-width: 0;
  margin-top: 16rpx;
}

.label {
  display: block;
  color: #5f6368;
  font-size: 23rpx;
}

.input {
  box-sizing: border-box;
  width: 100%;
  height: 78rpx;
  margin-top: 10rpx;
  padding: 0 20rpx;
  border: 1rpx solid #dadce0;
  border-radius: 6rpx;
  background: #ffffff;
  color: #202124;
  font-size: 28rpx;
}

.input:focus {
  border-color: #1a73e8;
}

.form-grid {
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.slider-card {
  padding: 16rpx 0 8rpx;
  border-bottom: 1rpx solid #f1f3f4;
}

.slider-head {
  color: #3c4043;
  font-size: 27rpx;
  font-weight: 600;
}

.picker {
  min-height: 78rpx;
  padding: 0 20rpx;
  margin-top: 14rpx;
  border: 1rpx solid #dadce0;
  border-radius: 6rpx;
  background: #ffffff;
  color: #202124;
  font-size: 27rpx;
}

.picker text:first-child {
  color: #5f6368;
}

.scenario-grid {
  grid-template-columns: repeat(3, minmax(0, 1fr));
}

.scenario {
  background: #e8f0fe;
  color: #1a73e8;
}

.factor-row,
.history-item {
  gap: 16rpx;
  padding: 18rpx 0;
  border-top: 1rpx solid #f1f3f4;
}

.factor-name,
.history-title {
  color: #202124;
  font-size: 27rpx;
  font-weight: 700;
}

.factor-value,
.history-meta {
  margin-top: 6rpx;
  color: #5f6368;
  font-size: 23rpx;
}

.factor-effect,
.history-price {
  flex-shrink: 0;
  color: #188038;
  font-size: 29rpx;
  font-weight: 800;
}

.reason,
.warning,
.empty {
  padding: 16rpx 0;
  border-top: 1rpx solid #f1f3f4;
  color: #3c4043;
  font-size: 26rpx;
  line-height: 1.5;
}

.warning {
  color: #b06000;
}

.empty {
  color: #5f6368;
  text-align: center;
}
