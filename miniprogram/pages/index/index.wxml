<view class="page">
  <view class="header">
    <view>
      <view class="eyebrow">个人开发版</view>
      <view class="title">微信小程序动态定价系统</view>
      <view class="subtitle">根据成本、竞品价、库存、需求、时段和会员身份实时生成建议售价。</view>
    </view>
  </view>

  <view class="price-panel">
    <view class="panel-label">建议售价</view>
    <view class="price-row">
      <text class="currency">¥</text>
      <text class="price">{{result.suggestedPrice}}</text>
    </view>
    <view class="metrics">
      <view class="metric">
        <text class="metric-value">¥{{result.profit}}</text>
        <text class="metric-label">单件利润</text>
      </view>
      <view class="metric">
        <text class="metric-value">{{result.margin}}%</text>
        <text class="metric-label">利润率</text>
      </view>
      <view class="metric">
        <text class="metric-value">¥{{result.expectedRevenue}}</text>
        <text class="metric-label">预估收入</text>
      </view>
    </view>
  </view>

  <view class="section">
    <view class="section-title">商品与价格</view>
    <view class="field">
      <text class="label">商品名称</text>
      <input class="input" value="{{form.productName}}" placeholder="例如：鲜花套餐" bindinput="onTextInput" />
    </view>
    <view class="grid">
      <view class="field">
        <text class="label">成本</text>
        <input class="input" type="digit" data-field="cost" value="{{form.cost}}" bindinput="onNumberInput" />
      </view>
      <view class="field">
        <text class="label">基准价</text>
        <input class="input" type="digit" data-field="basePrice" value="{{form.basePrice}}" bindinput="onNumberInput" />
      </view>
      <view class="field">
        <text class="label">竞品价</text>
        <input class="input" type="digit" data-field="competitorPrice" value="{{form.competitorPrice}}" bindinput="onNumberInput" />
      </view>
      <view class="field">
        <text class="label">目标毛利率 %</text>
        <input class="input" type="number" data-field="targetMargin" value="{{form.targetMargin}}" bindinput="onNumberInput" />
      </view>
    </view>
  </view>

  <view class="section">
    <view class="section-title">实时因素</view>
    <view class="slider-card">
      <view class="slider-head">
        <text>需求热度</text>
        <text class="slider-value">{{form.demand}}</text>
      </view>
      <slider min="0" max="100" step="1" value="{{form.demand}}" activeColor="#156f74" backgroundColor="#d9e2df" block-size="22" data-field="demand" bindchanging="onSliderChange" bindchange="onSliderChange" />
    </view>
    <view class="slider-card">
      <view class="slider-head">
        <text>库存水平</text>
        <text class="slider-value">{{form.inventory}}</text>
      </view>
      <slider min="0" max="100" step="1" value="{{form.inventory}}" activeColor="#156f74" backgroundColor="#d9e2df" block-size="22" data-field="inventory" bindchanging="onSliderChange" bindchange="onSliderChange" />
    </view>

    <view class="picker-row">
      <picker mode="selector" range="{{channelOptions}}" value="{{form.channelIndex}}" data-field="channelIndex" bindchange="onPickerChange">
        <view class="picker">
          <text class="label">销售渠道</text>
          <text>{{channelLabel}}</text>
        </view>
      </picker>
      <picker mode="selector" range="{{timeOptions}}" value="{{form.timeIndex}}" data-field="timeIndex" bindchange="onPickerChange">
        <view class="picker">
          <text class="label">时段场景</text>
          <text>{{timeLabel}}</text>
        </view>
      </picker>
      <picker mode="selector" range="{{tierOptions}}" value="{{form.tierIndex}}" data-field="tierIndex" bindchange="onPickerChange">
        <view class="picker">
          <text class="label">用户身份</text>
          <text>{{tierLabel}}</text>
        </view>
      </picker>
    </view>
  </view>

  <view class="section">
    <view class="section-title">快速场景</view>
    <view class="scenario-row">
      <button class="scenario" data-type="peak" bindtap="applyScenario">晚高峰</button>
      <button class="scenario" data-type="clearance" bindtap="applyScenario">清库存</button>
      <button class="scenario" data-type="holiday" bindtap="applyScenario">节假日</button>
    </view>
  </view>

  <view class="section">
    <view class="section-title">策略解释</view>
    <view class="range">保护价 ¥{{result.minPrice}} ｜ 上限价 ¥{{result.maxPrice}}</view>
    <view class="reason" wx:for="{{result.reasons}}" wx:key="*this">{{item}}</view>
  </view>

  <view class="section">
    <view class="section-head">
      <view class="section-title">策略数据</view>
      <view class="action-row">
        <button class="copy-btn ghost" bindtap="savePricing">保存</button>
        <button class="copy-btn" bindtap="copyStrategy">复制</button>
      </view>
    </view>
    <view class="json-box">{{strategyJson}}</view>
  </view>

  <view class="section" wx:if="{{savedPlans.length}}">
    <view class="section-title">最近保存</view>
    <view class="history-item" wx:for="{{savedPlans}}" wx:key="id">
      <view>
        <view class="history-title">{{item.productName}}</view>
        <view class="history-meta">{{item.timeScene}} ｜ {{item.channel}} ｜ {{item.userTier}}</view>
      </view>
      <view class="history-price">¥{{item.output.suggestedPrice}}</view>
    </view>
  </view>
</view>
